# ── Database ─────────────────────────────────────────
# Async PostgreSQL connection string (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://mcpgate:mcpgate@localhost:5432/mcpgate

# ── Security ─────────────────────────────────────────
# Master token used by your application to call the admin endpoints
# (create/list/revoke keys). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=change-me-to-a-secure-random-string

# ── Key format ───────────────────────────────────────
# Prefix prepended to every generated API key (e.g. mcp_sk_...)
# Change this to match your product/brand (e.g. myapp_sk_)
KEY_PREFIX=mcp_sk_
